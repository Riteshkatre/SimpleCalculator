<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="AppTextStyle" parent="Widget.AppCompat.TextView">
        <item name="android:fontFamily">@font/avenir_next</item>
        <item name="fontFamily">@font/avenir_next</item>
    </style>

    <style name="Base.Theme.SimpleCalculator" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/screen_background</item>
        <item name="android:navigationBarColor">@color/screen_background</item>
        <item name="android:windowBackground">@color/screen_background</item>
        <item name="android:fontFamily">@font/avenir_next</item>
        <item name="fontFamily">@font/avenir_next</item>
        <item name="android:textViewStyle">@style/AppTextStyle</item>
    </style>

    <style name="Theme.SimpleCalculator" parent="Base.Theme.SimpleCalculator" />

    <style name="Theme.SimpleCalculator.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:navigationBarColor">@color/splash_background</item>
        <item name="android:fontFamily">@font/avenir_next</item>
        <item name="fontFamily">@font/avenir_next</item>
        <item name="android:textViewStyle">@style/AppTextStyle</item>
    </style>

    <style name="CalculatorButtonBase" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/_72sdp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginHorizontal">@dimen/_4sdp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/_22ssp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">@dimen/_12sdp</item>
        <item name="android:paddingEnd">@dimen/_12sdp</item>
        <item name="android:fontFamily">@font/avenir_next</item>
        <item name="fontFamily">@font/avenir_next</item>
        <item name="backgroundTint">@null</item>
    </style>

    <style name="CalculatorNumberButton" parent="CalculatorButtonBase">
        <item name="android:background">@drawable/bg_calculator_number_button</item>
        <item name="android:textColor">@color/number_button_text</item>
        <item name="android:layout_width">@dimen/_20sdp</item>
        <item name="android:layout_height">@dimen/_40sdp</item>
    </style>

    <style name="CalculatorUtilityButton" parent="CalculatorButtonBase">
        <item name="android:background">@drawable/bg_calculator_utility_button</item>
        <item name="android:textColor">@color/utility_button_text</item>
        <item name="android:layout_width">@dimen/_20sdp</item>
        <item name="android:layout_height">@dimen/_40sdp</item>
    </style>

    <style name="CalculatorOperatorButton" parent="CalculatorButtonBase">
        <item name="android:background">@drawable/bg_calculator_operator_button</item>
        <item name="android:textColor">@color/operator_button_text</item>
        <item name="android:layout_width">@dimen/_20sdp</item>
        <item name="android:layout_height">@dimen/_40sdp</item>
    </style>

    <style name="TopBarIconButton">
        <item name="android:layout_width">@dimen/_28sdp</item>
        <item name="android:layout_height">@dimen/_28sdp</item>
        <item name="android:background">@drawable/bg_top_bar_icon_button</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:fontFamily">@font/avenir_next</item>
        <item name="fontFamily">@font/avenir_next</item>
        <item name="android:contentDescription">@string/navigate_back</item>
        <item name="android:padding">@dimen/_2sdp</item>

    </style>

    <style name="TopBarIconButtonBg">
        <item name="android:layout_width">@dimen/_40sdp</item>
        <item name="android:layout_height">@dimen/_40sdp</item>
        <item name="android:background">@drawable/bg_top_bar_icon_button</item>
        <item name="android:padding">@dimen/_12sdp</item>
        <item name="android:scaleType">centerInside</item>
        <item name="android:fontFamily">@font/avenir_next</item>
        <item name="fontFamily">@font/avenir_next</item>
        <item name="android:contentDescription">@string/navigate_back</item>
    </style>
</resources>
