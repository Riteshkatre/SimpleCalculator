<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/screen_background"
    tools:context=".SettingsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_16sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">


            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnBack"
                style="@style/TopBarIconButton"
                android:contentDescription="@string/navigate_back"
                app:srcCompat="@drawable/baseline_keyboard_backspace_24" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_12sdp"
                android:text="Settings"
                android:textColor="@color/display_text"
                android:textSize="@dimen/_20ssp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_18sdp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="@dimen/_24sdp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_18sdp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Theme"
                    android:textColor="@color/display_text"
                    android:textSize="@dimen/_18ssp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/themeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_12sdp">

                    <RadioButton
                        android:id="@+id/themeSystem"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="System default"
                        android:textColor="@color/display_text" />

                    <RadioButton
                        android:id="@+id/themeLight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Light theme"
                        android:textColor="@color/display_text" />

                    <RadioButton
                        android:id="@+id/themeDark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dark theme"
                        android:textColor="@color/display_text" />
                </RadioGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWatchRewardedAd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:text="@string/watch_rewarded_ad"
                    android:textAllCaps="false"
                    android:textColor="@color/display_text"
                    app:backgroundTint="@color/screen_background"
                    app:cornerRadius="@dimen/_18sdp"
                    app:strokeWidth="0dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:id="@+id/bannerAdContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp" />
    </LinearLayout>
</ScrollView>
