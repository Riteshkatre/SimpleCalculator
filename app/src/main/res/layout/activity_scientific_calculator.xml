<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    tools:context=".ScientificCalculatorActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_16sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnBack"
                style="@style/TopBarIconButton"
                android:contentDescription="@string/navigate_back"
                app:srcCompat="@drawable/baseline_keyboard_backspace_24" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_12sdp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scientific Mode"
                    android:textColor="@color/display_text"
                    android:textSize="@dimen/_20ssp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Advanced calculator tools"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_12ssp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="@dimen/_28sdp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_20sdp">

                <TextView
                    android:id="@+id/expressionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:text="0"
                    android:textColor="@color/display_text"
                    android:textSize="@dimen/_22ssp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/previewText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:gravity="end"
                    android:includeFontPadding="false"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_22ssp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyResult"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_weight="1"
                        android:text="Copy"
                        android:textAllCaps="false"
                        android:textColor="@color/display_text"
                        android:textSize="@dimen/_12ssp"
                        app:backgroundTint="@color/screen_background"
                        app:cornerRadius="@dimen/_20sdp"
                        app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShareResult"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginStart="@dimen/_8sdp"
                        android:layout_weight="1"
                        android:text="Share"
                        android:textAllCaps="false"
                        android:textColor="@color/display_text"
                        android:textSize="@dimen/_12ssp"
                        app:backgroundTint="@color/screen_background"
                        app:cornerRadius="@dimen/_20sdp"
                        app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveResult"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginStart="@dimen/_8sdp"
                        android:layout_weight="1"
                        android:text="Save"
                        android:textAllCaps="false"
                        android:textColor="@color/display_text"
                        android:textSize="@dimen/_12ssp"
                        app:backgroundTint="@color/screen_background"
                        app:cornerRadius="@dimen/_20sdp"
                        app:strokeWidth="0dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSin"
                    style="@style/CalculatorNumberButton"
                    android:text="sin" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCos"
                    style="@style/CalculatorNumberButton"
                    android:text="cos" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnTan"
                    style="@style/CalculatorNumberButton"
                    android:text="tan" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAngleMode"
                    style="@style/CalculatorOperatorButton"
                    android:text="deg" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnPi"
                    style="@style/CalculatorNumberButton"
                    android:text="π" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLog"
                    style="@style/CalculatorNumberButton"
                    android:text="log" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLn"
                    style="@style/CalculatorNumberButton"
                    android:text="ln" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSquare"
                    style="@style/CalculatorNumberButton"
                    android:text="x²" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCube"
                    style="@style/CalculatorNumberButton"
                    android:text="x³" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSqrt"
                    style="@style/CalculatorNumberButton"
                    android:text="√" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnReciprocal"
                    style="@style/CalculatorUtilityButton"
                    android:text="1/x" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnFactorial"
                    style="@style/CalculatorUtilityButton"
                    android:text="!" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnInverse"
                    style="@style/CalculatorUtilityButton"
                    android:text="inv" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnClearScientific"
                    style="@style/CalculatorUtilityButton"
                    android:text="AC"
                    android:visibility="gone" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDummyScientific"
                    style="@style/CalculatorUtilityButton"
                    android:text=""
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/numberCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnClear"
                    style="@style/CalculatorUtilityButton"
                    android:text="AC" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnPercent"
                    style="@style/CalculatorUtilityButton"
                    android:text="%" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBackspace"
                    style="@style/CalculatorUtilityButton"
                    android:text="⌫" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDivide"
                    style="@style/CalculatorOperatorButton"
                    android:text="÷" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn7"
                    style="@style/CalculatorNumberButton"
                    android:text="7" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn8"
                    style="@style/CalculatorNumberButton"
                    android:text="8" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn9"
                    style="@style/CalculatorNumberButton"
                    android:text="9" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMultiply"
                    style="@style/CalculatorOperatorButton"
                    android:text="×" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn4"
                    style="@style/CalculatorNumberButton"
                    android:text="4" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn5"
                    style="@style/CalculatorNumberButton"
                    android:text="5" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn6"
                    style="@style/CalculatorNumberButton"
                    android:text="6" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMinus"
                    style="@style/CalculatorOperatorButton"
                    android:text="−" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn1"
                    style="@style/CalculatorNumberButton"
                    android:text="1" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn2"
                    style="@style/CalculatorNumberButton"
                    android:text="2" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn3"
                    style="@style/CalculatorNumberButton"
                    android:text="3" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnPlus"
                    style="@style/CalculatorOperatorButton"
                    android:text="+" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDoubleZero"
                    style="@style/CalculatorUtilityButton"
                    android:text="00" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn0"
                    style="@style/CalculatorNumberButton"
                    android:text="0" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDecimal"
                    style="@style/CalculatorNumberButton"
                    android:text="." />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnEquals"
                    style="@style/CalculatorOperatorButton"
                    android:text="=" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/bannerAdContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
