<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/layoutMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/calculator_title"
                android:textColor="@color/secondary_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/btnScientificMode"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/bg_top_bar_icon_button"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/btnScientificModeIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/calculator" />
            </FrameLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMoreCalculators"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginStart="10dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/card_background"
                app:cornerRadius="22dp"
                app:icon="@drawable/dots"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@null"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOverflowMenu"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginStart="10dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:padding="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/card_background"
                app:cornerRadius="22dp"
                app:icon="@drawable/menu"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@null"
                app:strokeWidth="0dp" />

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/materialCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/layoutMain"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/secondary_text"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/expressionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:includeFontPadding="false"
                    android:text="0"
                    android:textColor="@color/display_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/previewText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="end"
                    android:includeFontPadding="false"
                    android:textColor="@color/secondary_text"
                    android:textSize="32sp"
                    android:textStyle="bold" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyResult"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Copy"
                        android:textAllCaps="false"
                        android:textColor="@color/display_text"
                        android:textSize="12sp"
                        app:backgroundTint="@color/screen_background"
                        app:cornerRadius="20dp"
                        app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShareResult"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Share"
                        android:textAllCaps="false"
                        android:textColor="@color/display_text"
                        android:textSize="12sp"
                        app:backgroundTint="@color/screen_background"
                        app:cornerRadius="20dp"
                        app:strokeWidth="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveResult"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Save"
                        android:textAllCaps="false"
                        android:textColor="@color/display_text"
                        android:textSize="12sp"
                        app:backgroundTint="@color/screen_background"
                        app:cornerRadius="20dp"
                        app:strokeWidth="0dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/scientificPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@+id/numberCard"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSin"
                    style="@style/CalculatorNumberButton"
                    android:text="sin" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCos"
                    style="@style/CalculatorNumberButton"
                    android:text="cos" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnTan"
                    style="@style/CalculatorNumberButton"
                    android:text="tan" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAngleMode"
                    style="@style/CalculatorOperatorButton"
                    android:text="deg" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnPi"
                    style="@style/CalculatorNumberButton"
                    android:text="π" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLog"
                    style="@style/CalculatorNumberButton"
                    android:text="log" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLn"
                    style="@style/CalculatorNumberButton"
                    android:text="ln" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSquare"
                    style="@style/CalculatorNumberButton"
                    android:text="x²" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCube"
                    style="@style/CalculatorNumberButton"
                    android:text="x³" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSqrt"
                    style="@style/CalculatorNumberButton"
                    android:text="√" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnReciprocal"
                    style="@style/CalculatorUtilityButton"
                    android:text="1/x" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnFactorial"
                    style="@style/CalculatorUtilityButton"
                    android:text="!" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnInverse"
                    style="@style/CalculatorUtilityButton"
                    android:text="inv" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnClearScientific"
                    style="@style/CalculatorUtilityButton"
                    android:text="AC"
                    android:visibility="gone" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDummyScientific"
                    style="@style/CalculatorUtilityButton"
                    android:text=""
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/numberCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@+id/bannerAdContainer"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="10dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnClear"
                    style="@style/CalculatorUtilityButton"
                    android:text="AC" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnPercent"
                    style="@style/CalculatorUtilityButton"
                    android:text="%" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBackspace"
                    style="@style/CalculatorUtilityButton"
                    android:text="⌫" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDivide"
                    style="@style/CalculatorOperatorButton"
                    android:text="÷" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn7"
                    style="@style/CalculatorNumberButton"
                    android:text="7" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn8"
                    style="@style/CalculatorNumberButton"
                    android:text="8" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn9"
                    style="@style/CalculatorNumberButton"
                    android:text="9" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMultiply"
                    style="@style/CalculatorOperatorButton"
                    android:text="×" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn4"
                    style="@style/CalculatorNumberButton"
                    android:text="4" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn5"
                    style="@style/CalculatorNumberButton"
                    android:text="5" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn6"
                    style="@style/CalculatorNumberButton"
                    android:text="6" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMinus"
                    style="@style/CalculatorOperatorButton"
                    android:text="−" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn1"
                    style="@style/CalculatorNumberButton"
                    android:text="1" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn2"
                    style="@style/CalculatorNumberButton"
                    android:text="2" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn3"
                    style="@style/CalculatorNumberButton"
                    android:text="3" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnPlus"
                    style="@style/CalculatorOperatorButton"
                    android:text="+" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDoubleZero"
                    style="@style/CalculatorUtilityButton"
                    android:text="00" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn0"
                    style="@style/CalculatorNumberButton"
                    android:text="0" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDecimal"
                    style="@style/CalculatorNumberButton"
                    android:text="." />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnEquals"
                    style="@style/CalculatorOperatorButton"
                    android:text="=" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/bannerAdContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true" />
    </RelativeLayout>
</RelativeLayout>
