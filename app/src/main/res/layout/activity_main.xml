<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".MainActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/calculatorCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/calculator_title"
                    android:textColor="@color/secondary_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/themeToggle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:contentDescription="@string/switch_to_dark_theme"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/theme_toggle_icon"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="26dp"
                    app:iconTint="@null"
                    app:backgroundTint="@color/display_text"
                    app:cornerRadius="22dp"
                    app:strokeWidth="0dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="end|bottom"
                android:orientation="vertical"
                android:paddingTop="28dp"
                android:paddingBottom="24dp">

                <EditText
                    android:id="@+id/expressionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:background="@null"
                    android:cursorVisible="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:includeFontPadding="false"
                    android:inputType="textNoSuggestions"
                    android:longClickable="false"
                    android:singleLine="true"
                    android:text="0"
                    android:textColor="@color/display_text"
                    android:textSize="58sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/previewText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="end"
                    android:includeFontPadding="false"
                    android:textColor="@color/secondary_text"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClear"
                        style="@style/CalculatorUtilityButton"
                        android:text="AC" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleSign"
                        style="@style/CalculatorUtilityButton"
                        android:text="⌫" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPercent"
                        style="@style/CalculatorUtilityButton"
                        android:text="%" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDivide"
                        style="@style/CalculatorOperatorButton"
                        android:text="÷" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn7"
                        style="@style/CalculatorNumberButton"
                        android:text="7" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn8"
                        style="@style/CalculatorNumberButton"
                        android:text="8" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn9"
                        style="@style/CalculatorNumberButton"
                        android:text="9" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMultiply"
                        style="@style/CalculatorOperatorButton"
                        android:text="×" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn4"
                        style="@style/CalculatorNumberButton"
                        android:text="4" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn5"
                        style="@style/CalculatorNumberButton"
                        android:text="5" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn6"
                        style="@style/CalculatorNumberButton"
                        android:text="6" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMinus"
                        style="@style/CalculatorOperatorButton"
                        android:text="−" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn1"
                        style="@style/CalculatorNumberButton"
                        android:text="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn2"
                        style="@style/CalculatorNumberButton"
                        android:text="2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn3"
                        style="@style/CalculatorNumberButton"
                        android:text="3" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlus"
                        style="@style/CalculatorOperatorButton"
                        android:text="+" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBackspace"
                        style="@style/CalculatorUtilityButton"
                        android:text="00" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn0"
                        style="@style/CalculatorNumberButton"
                        android:text="0" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDecimal"
                        style="@style/CalculatorNumberButton"
                        android:text="." />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEquals"
                        style="@style/CalculatorOperatorButton"
                        android:text="=" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
