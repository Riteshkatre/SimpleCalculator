<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    tools:context=".CurrencyConverterActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/baseline_keyboard_backspace_24"
                android:tint="@color/display_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Currency converter"
                android:textColor="@color/display_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <Spinner
                                android:id="@+id/fromCurrencySpinner"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@android:color/transparent"
                                android:padding="0dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=">"
                                android:textColor="@color/secondary_text"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/fromAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="100"
                            android:textColor="@color/operator_button_background"
                            android:textSize="42sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <Spinner
                                android:id="@+id/toCurrencySpinner"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@android:color/transparent"
                                android:padding="0dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=">"
                                android:textColor="@color/secondary_text"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/toAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="9,471.7016"
                            android:textColor="@color/display_text"
                            android:textSize="42sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSwap"
                android:layout_width="90dp"
                android:layout_height="312dp"
                android:layout_marginStart="12dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="↔"
                    android:textColor="@color/display_text"
                    android:textSize="34sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/lastUpdated"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/secondary_text"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefresh"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="↻"
                android:textAllCaps="false"
                android:textColor="@color/secondary_text"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="20dp"
                app:strokeWidth="0dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <GridLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:columnCount="3">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn7"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="7"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn8"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="8"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn9"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="9"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn4"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="4"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn5"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="5"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn6"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="6"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn1"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="1"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn2"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="2"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn3"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="3"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDoubleZero"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="00"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn0"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="0"
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDecimal"
                    android:layout_width="0dp"
                    android:layout_height="76dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="."
                    android:textAllCaps="false"
                    android:textColor="@color/number_button_text"
                    app:backgroundTint="@color/number_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />
            </GridLayout>

            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="336dp"
                android:layout_marginStart="6dp"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClear"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:text="AC"
                    android:textAllCaps="false"
                    android:textColor="@color/utility_button_text"
                    app:backgroundTint="@color/utility_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackspace"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:text=""
                    app:icon="@drawable/baseline_keyboard_backspace_24"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="@color/utility_button_text"
                    app:backgroundTint="@color/utility_button_background"
                    app:cornerRadius="38dp"
                    app:strokeWidth="0dp" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/bannerAdContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
