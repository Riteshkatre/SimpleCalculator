<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    tools:context=".PrivateVaultActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_16sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnBack"
                style="@style/TopBarIconButton"
                android:contentDescription="@string/navigate_back"
                app:srcCompat="@drawable/baseline_keyboard_backspace_24" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_12sdp"
                android:text="Private Vault"
                android:textColor="@color/display_text"
                android:textSize="@dimen/_24ssp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/passwordCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_18sdp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="@dimen/_24sdp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/_18sdp">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create a passcode to protect your files."
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_20ssp" />

                <TextView
                    android:id="@+id/passcodeLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_12sdp"
                    android:text="Set Passcode"
                    android:textColor="@color/display_text"
                    android:textSize="@dimen/_18ssp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_12sdp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passcodeInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:hint="Passcode" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPasswordAction"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_48sdp"
                    android:layout_marginTop="@dimen/_12sdp"
                    android:text="Create Vault"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/operator_button_background"
                    app:cornerRadius="@dimen/_24sdp"
                    app:strokeWidth="0dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/vaultSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_18sdp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="@dimen/_24sdp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_18sdp">

                    <TextView
                        android:id="@+id/vaultWelcomeText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Files are stored privately inside the app."
                        android:textColor="@color/display_text"
                        android:textSize="@dimen/_16ssp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/folderSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_12sdp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_12sdp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnImportFile"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/_44sdp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_calculator_operator_button"
                            android:clickable="true"
                            android:gravity="center"
                            android:focusable="true"
                            android:text="Add File"
                            android:textColor="@color/display_text"
                            android:textSize="@dimen/_14ssp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnNewFolder"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/_44sdp"
                            android:layout_marginStart="@dimen/_8sdp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_calculator_utility_button"
                            android:clickable="true"
                            android:gravity="center"
                            android:focusable="true"
                            android:text="New Folder"
                            android:textColor="@color/display_text"
                            android:textSize="@dimen/_14ssp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnLockVault"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/_44sdp"
                            android:layout_marginStart="@dimen/_8sdp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_calculator_utility_button"
                            android:clickable="true"
                            android:gravity="center"
                            android:focusable="true"
                            android:text="Lock"
                            android:textColor="@color/display_text"
                            android:textSize="@dimen/_14ssp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_16sdp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="@dimen/_24sdp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_18sdp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Manage Hidden Files"
                        android:textColor="@color/display_text"
                        android:textSize="@dimen/_18ssp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/emptyStateText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_12sdp"
                        android:text="No files in this folder."
                        android:textColor="@color/secondary_text"
                        android:textSize="@dimen/_14ssp" />

                    <GridLayout
                        android:id="@+id/vaultGridContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_12sdp"
                        android:columnCount="2"
                        android:useDefaultMargins="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/bannerAdContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
