<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/_20sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnBack"
                style="@style/TopBarIconButton"
                android:contentDescription="@string/navigate_back"
                app:srcCompat="@drawable/baseline_keyboard_backspace_24" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_12sdp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/fileTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="File preview"
                    android:textColor="@color/display_text"
                    android:textSize="@dimen/_20ssp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/fileMime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Opening inside the app"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/_12ssp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_18sdp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="@dimen/_24sdp"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_520sdp"
                android:minHeight="@dimen/_320sdp"
                android:padding="@dimen/_14sdp">

                <ProgressBar
                    android:id="@+id/loadingIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/imagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/app_name"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />

                <VideoView
                    android:id="@+id/videoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <ScrollView
                    android:id="@+id/textScroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/textPreview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="@dimen/_4sdp"
                        android:textColor="@color/display_text"
                        android:textSize="@dimen/_14ssp" />
                </ScrollView>

                <LinearLayout
                    android:id="@+id/unsupportedPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/_24sdp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/unsupportedTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Preview not available"
                        android:textColor="@color/display_text"
                        android:textSize="@dimen/_20ssp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/unsupportedMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:gravity="center"
                        android:text="This file type can still be opened externally."
                        android:textColor="@color/secondary_text"
                        android:textSize="@dimen/_14ssp" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenExternally"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_16sdp"
            android:text="Open externally"
            android:textAllCaps="false"
            app:cornerRadius="@dimen/_18sdp"
            app:backgroundTint="@color/display_text"
            android:textColor="@color/screen_background" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
